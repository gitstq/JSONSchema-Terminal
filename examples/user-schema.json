{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/user-schema.json",
  "title": "User",
  "description": "A user profile in the system",
  "type": "object",
  "required": ["id", "username", "email"],
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique identifier for the user",
      "minimum": 1
    },
    "username": {
      "type": "string",
      "description": "User's login name",
      "minLength": 3,
      "maxLength": 50,
      "pattern": "^[a-zA-Z0-9_]+$"
    },
    "email": {
      "type": "string",
      "description": "User's email address",
      "format": "email"
    },
    "profile": {
      "type": "object",
      "description": "User's profile information",
      "properties": {
        "firstName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "lastName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "age": {
          "type": "integer",
          "minimum": 0,
          "maximum": 150
        },
        "avatar": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "roles": {
      "type": "array",
      "description": "User's roles in the system",
      "items": {
        "type": "string",
        "enum": ["admin", "user", "moderator", "guest"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "settings": {
      "type": "object",
      "properties": {
        "notifications": {
          "type": "boolean",
          "default": true
        },
        "theme": {
          "type": "string",
          "enum": ["light", "dark", "auto"],
          "default": "auto"
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    }
  },
  "additionalProperties": false
}
